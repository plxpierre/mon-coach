<%# app/views/programs/show.html.erb %>

<% program_title = "Program #12" %>
<% program_weeks = 8 %>
<% days_per_week = 3 %>

<% weeks = (1..program_weeks).map do |w| %>
  <% {
    index: w,
    days: (1..days_per_week).map do |d|
      {
        index: d,
        title: "Day #{d}",
        actions: [
          { reps: "3x12", name: "Goblet Squat", rest: "60s" },
          { reps: "3x10", name: "Push-up", rest: "60s" },
          { reps: "4x30s", name: "Plank", rest: "45s" }
        ]
      }
    end
  } %>
<% end %>

<div class="flex items-start justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-bold"><%= program_title %></h1>
    <p class="opacity-70 mt-1">
      Duration: <%= program_weeks %> weeks • Training days/week: <%= days_per_week %>
    </p>
  </div>

  <div class="flex gap-2">
    <a class="btn btn-outline" href="#">Edit</a>
    <a class="btn btn-ghost" href="#">Back</a>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
  <% weeks.each do |week| %>
    <div class="card bg-base-100 shadow-xl border border-base-300">
      <div class="card-body flex flex-col">
        <div class="flex items-start justify-between">
          <div>
            <h2 class="card-title">Week <%= week[:index] %></h2>
            <p class="opacity-70 text-sm">Plan overview</p>
          </div>
          <span class="badge badge-outline"><%= days_per_week %> days</span>
        </div>

        <div class="grid grid-cols-1 gap-3 mt-4">
          <% week[:days].each do |day| %>
            <div class="rounded-xl border border-base-300 bg-base-200/40 p-4">
              <div class="flex items-center justify-between mb-3">
                <div class="font-semibold"><%= day[:title] %></div>
                <span class="badge badge-neutral badge-sm"><%= day[:actions].size %> exercises</span>
              </div>

              <div class="space-y-2">
                <% day[:actions].each do |a| %>
                  <div class="flex items-center justify-between gap-3">
                    <div class="min-w-0">
                      <div class="font-medium truncate"><%= a[:name] %></div>
                      <div class="text-xs opacity-70">
                        Reps: <span class="font-semibold"><%= a[:reps] %></span>
                        • Rest: <span class="font-semibold"><%= a[:rest] %></span>
                      </div>
                    </div>
                    <button class="btn btn-ghost btn-sm">View</button>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="card-actions mt-auto justify-end pt-4">
          <button class="btn btn-primary btn-sm">Week details</button>
        </div>
      </div>
    </div>
  <% end %>
</div>
