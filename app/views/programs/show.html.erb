
<div class="max-w-2xl mx-auto p-4 py-10 font-sans">

  <h1 class="text-2xl font-bold mb-8 text-gray-900"><%= @program.title %></h1>

  <div class="space-y-10">
    <% @program.weeks.each do |week| %>
      <section>
        <h2 class="text-sm font-black uppercase tracking-widest text-blue-600 mb-4">
          Semaine <%= week.week_number %>
        </h2>

        <div class="space-y-4">
          <% week.week_program.each do |seance| %>
            <div class="p-5 bg-gray-50 rounded-lg border border-gray-100 whitespace-pre-line text-gray-700 leading-relaxed">
              <%= seance %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>
<div class="mb-6 p-3">
  <%= link_to programs_path, class:"text-gray-500 hover:text-red-600 transition flex items-center gap-2 text-sm font-medium" do %>
    <span>←</span>  Back
  <% end %>
</div>

<div class="mt-8 pt-6 border-t text-gray-500">
  <%= button_to "Delete",
      program_path(@program),
      method: :delete,
      data: { turbo_confirm: "Delete ?" },
      class:"text-sm text-red-600 hover:underline" %>
</div>
