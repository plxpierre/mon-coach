<%# app/views/programs/show.html.erb %>
<div
  class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10"
  data-controller="program-show">
  <header class="mb-8">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight">
          <%= @program.title %>
        </h1>
        <p class="text-sm opacity-70 mt-2">
          Navigate week by week. Use the left stepper to jump instantly.
        </p>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to root_path, class: "btn btn-ghost btn-sm gap-2" do %>
          <i class="fa-solid fa-arrow-left text-xs"></i>
          Back
        <% end %>
        <%= button_to program_path(@program),
          method: :delete,
          data: { turbo_confirm: "Delete ?" },
          form: { class: "inline-block" },
          class: "btn btn-outline btn-sm gap-2 text-error" do %>
          <i class="fa-solid fa-trash text-xs"></i>
          Delete
        <% end %>
      </div>
    </div>
  </header>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    <%# LEFT: stepper %>
    <aside class="lg:col-span-3">
      <%# Placeholder keeps layout when panel becomes fixed %>
      <div class="hidden" data-program-show-target="stepperPlaceholder"></div>
      <div
        class="card bg-base-100 border border-base-300 shadow-sm
               lg:sticky lg:top-28
               max-h-[calc(100vh-8rem)] overflow-auto"
        data-program-show-target="stepperPanel">
        <div class="card-body p-5">
          <div class="flex items-center justify-between mb-4">
            <div class="font-semibold flex items-center gap-2">
              <i class="fa-solid fa-layer-group opacity-70"></i>
              Weeks
            </div>
            <span class="badge badge-outline"><%= @program.weeks.size %></span>
          </div>
          <ul class="steps steps-vertical w-full">
            <% @program.weeks.each_with_index do |week, idx| %>
              <li
                class="step <%= idx == 0 ? "step-primary" : "" %>"
                data-program-show-target="weekStep"
                data-target="week-<%= week.week_number %>">
                <a
                  href="#week-<%= week.week_number %>"
                  class="link link-hover font-semibold"
                  data-action="program-show#jump">
                  Week <%= week.week_number %>
                </a>
              </li>
            <% end %>
          </ul>
          <p class="text-xs opacity-70 mt-4">
            This panel follows your scroll. Click a week to jump.
          </p>
        </div>
      </div>
    </aside>
    <%# RIGHT: content %>
    <main class="lg:col-span-9 space-y-10">
      <% @program.weeks.each do |week| %>
        <section
          id="week-<%= week.week_number %>"
          class="scroll-mt-28"
          data-program-show-target="weekSection">
          <div class="card bg-base-100 border border-base-300 shadow-sm">
            <div class="card-body p-6">
              <div class="flex items-start justify-between gap-4 mb-6">
                <div class="min-w-0">
                  <h2 class="text-lg sm:text-xl font-semibold tracking-tight flex items-center gap-2">
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-2xl border border-base-300 bg-base-200">
                      <i class="fa-solid fa-calendar-week text-xs opacity-70"></i>
                    </span>
                    Week <%= week.week_number %>
                  </h2>
                  <p class="text-sm opacity-70 mt-1">
                    Switch days using lifted tabs.
                  </p>
                </div>
                <span class="badge badge-outline">
                  <%= (week.week_program || []).size %> days
                </span>
              </div>
              <% days = (week.week_program || []) %>
              <% if days.any? %>
                <% tab_group = "week_tabs_#{week.week_number}" %>
                <div class="tabs tabs-lift">
                  <% days.each_with_index do |seance, i| %>
                    <label class="tab">
                      <input type="radio" name="<%= tab_group %>" <%= "checked" if i == 0 %>>
                      <i class="fa-solid fa-circle-play text-xs me-2 opacity-80"></i>
                      Day <%= i + 1 %>
                    </label>
                    <div class="tab-content bg-base-100 border-base-300 p-6">
                      <div class="rounded-2xl border border-base-300 bg-base-200/40 p-5 leading-relaxed prose max-w-none">
                        <% seance = JSON.parse(seance.gsub("=>", ":")) %>
                        <%# <%= Kramdown::Document.new(seance).to_html.html_safe %>
                        <h3 class="text-xl my-3 font-medium"><%= seance["day"] %> : <%= seance["session_name"] %></h3>
                        <h4 class="text-l my-3 font-semibold"><%= seance["description"] %></h4>
                        <p class="text-l my-2 font-medium">Today's exercises : </p>
                        <ul>
                          <% seance["exercises"].each do |exercise| %>
                            <li>- <%= exercise %></li>
                          <% end %>
                        </ul>
                        <h4 class="text-l my-3 font-semibold"><%= seance["final_sentence"] %></h4>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div class="rounded-2xl border border-base-300 bg-base-200/40 p-5 text-sm opacity-70">
                  No sessions for this week yet.
                </div>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>
    </main>
  </div>
  <%# Back to top %>
  <button
    type="button"
    class="btn btn-primary btn-circle fixed bottom-6 right-6 shadow-md opacity-0 pointer-events-none transition-opacity duration-200"
    data-program-show-target="backToTop"
    data-action="program-show#backToTopClick"
    aria-label="Back to top"
    title="Back to top">
    <i class="fa-solid fa-arrow-up text-sm"></i>
  </button>
</div>
<%= console %>
