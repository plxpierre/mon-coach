<h1 class="text-2xl font-bold mb-6">Créer un programme</h1>
<%= form_with model: @program, local: true do |f| %>
  <div class="mb-4">
    <%= f.label :number_of_week, "Number of weeks (1-18)", class:"block mb-1 font-medium" %>
    <%= f.number_field :number_of_week,
                              min: 1,
                              max: 18,
                              class:"w-full border rounded px-3 py-2" %>
  </div>
  <div class="mb-4">
    <%= f.label :level, class:"block mb-1 font-medium" %>
    <%= f.select :level,
                        Program::LEVELS,
                        {},
                        class:"w-full border rounded px-3 py-2" %>
  </div>
  <div class="mb-4">
    <%= f.label :sport, class:"block mb-1 font-medium" %>
    <%= f.select :sport,
                        Program::SPORTS,
                        {},
                        class:"w-full border rounded px-3 py-2" %>
  </div>
  <div class="mb-4">
    <%= f.label :goal, class:"block mb-1 font-medium" %>
    <%= f.text_area :goal,
                    class:"w-full border rounded px-3 py-2",
                    rows: 3 %>
  </div>
  <div class="mb-4">
    <%= f.label :tools, class:"block mb-1 font-medium" %>
    <%= f.text_area :tools,
                    placeholder: "none",
                    class:"w-full border rounded px-3 py-2",
                    rows: 2 %>
  </div>
  <div class="mb-6">
    <%= f.label :medical_conditions, class:"block mb-1 font-medium" %>
    <%= f.text_area :medical_conditions,
                    placeholder: "none",
                    class:"w-full border rounded px-3 py-2",
                    rows: 2 %>
  </div>
  <%= f.submit "Create",
               class:"bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition" %>
<% end %>

<div class="mb-6 p-3">
  <%= link_to programs_path, class: "text-gray-500 hover:text-red-600 transition flex items-center gap-2 text-sm font-medium" do %>
    <span>←</span> Return
  <% end %>
</div>
