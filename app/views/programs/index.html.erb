<h1 class="text-2xl font-bold mb-6">My programs</h1>
<!-- Top dashboard -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8 items-stretch">
  <!-- Effort vs Results (2/3 width) -->
  <div class="lg:col-span-2">
    <div class="card bg-base-100 shadow-xl border border-base-300 h-full">
      <div class="card-body flex flex-col">
        <div class="flex items-start justify-between">
          <div>
            <h2 class="card-title">Effort vs Results</h2>
            <p class="opacity-70 text-sm">
              Consistent effort usually produces visible results after week 3–4.
            </p>
          </div>
          <span class="badge badge-outline">Last 8 weeks</span>
        </div>
        <div class="mt-6 space-y-4">
          <div class="grid grid-cols-12 gap-3 items-center">
            <div class="col-span-2 text-sm opacity-70">Week 1</div>
            <div class="col-span-5">
              <div class="flex justify-between text-xs opacity-70 mb-1">
                <span>Effort</span>
                <span>40</span>
              </div>
              <progress class="progress w-full" value="40" max="100"></progress>
            </div>
            <div class="col-span-5">
              <div class="flex justify-between text-xs opacity-70 mb-1">
                <span>Results</span>
                <span>15</span>
              </div>
              <progress class="progress w-full" value="15" max="100"></progress>
            </div>
          </div>
          <div class="grid grid-cols-12 gap-3 items-center">
            <div class="col-span-2 text-sm opacity-70">Week 2</div>
            <div class="col-span-5">
              <div class="flex justify-between text-xs opacity-70 mb-1">
                <span>Effort</span>
                <span>55</span>
              </div>
              <progress class="progress w-full" value="55" max="100"></progress>
            </div>
            <div class="col-span-5">
              <div class="flex justify-between text-xs opacity-70 mb-1">
                <span>Results</span>
                <span>25</span>
              </div>
              <progress class="progress w-full" value="25" max="100"></progress>
            </div>
          </div>
          <div class="grid grid-cols-12 gap-3 items-center">
            <div class="col-span-2 text-sm opacity-70">Week 3</div>
            <div class="col-span-5">
              <div class="flex justify-between text-xs opacity-70 mb-1">
                <span>Effort</span>
                <span>65</span>
              </div>
              <progress class="progress w-full" value="65" max="100"></progress>
            </div>
            <div class="col-span-5">
              <div class="flex justify-between text-xs opacity-70 mb-1">
                <span>Results</span>
                <span>35</span>
              </div>
              <progress class="progress w-full" value="35" max="100"></progress>
            </div>
          </div>
          <div class="grid grid-cols-12 gap-3 items-center">
            <div class="col-span-2 text-sm opacity-70">Week 4</div>
            <div class="col-span-5">
              <div class="flex justify-between text-xs opacity-70 mb-1">
                <span>Effort</span>
                <span>70</span>
              </div>
              <progress class="progress w-full" value="70" max="100"></progress>
            </div>
            <div class="col-span-5">
              <div class="flex justify-between text-xs opacity-70 mb-1">
                <span>Results</span>
                <span>50</span>
              </div>
              <progress class="progress w-full" value="50" max="100"></progress>
            </div>
          </div>
        </div>
        <div class="divider my-6"></div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="rounded-xl border border-base-300 bg-base-200/40 p-4">
            <div class="text-sm opacity-70">Consistency</div>
            <div class="text-2xl font-bold mt-1">78%</div>
            <div class="text-xs opacity-70 mt-1">
              Sessions completed / planned
            </div>
          </div>
          <div class="rounded-xl border border-base-300 bg-base-200/40 p-4">
            <div class="text-sm opacity-70">Average effort</div>
            <div class="text-2xl font-bold mt-1">6.4 / 10</div>
            <div class="text-xs opacity-70 mt-1">
              Perceived exertion
            </div>
          </div>
          <div class="rounded-xl border border-base-300 bg-base-200/40 p-4">
            <div class="text-sm opacity-70">Trend</div>
            <div class="text-2xl font-bold mt-1">Improving</div>
            <div class="text-xs opacity-70 mt-1">
              Results increasing weekly
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Tools card (1/3 width) -->
  <div class="lg:col-span-1">
    <div class="card bg-base-100 shadow-xl border border-base-300 h-full">
      <div class="card-body flex flex-col">
        <div class="flex items-start justify-between">
          <div>
            <h2 class="card-title">Your tools</h2>
            <p class="opacity-70 text-sm">
              Based on your onboarding setup
            </p>
          </div>
          <span class="badge badge-neutral">Equipment</span>
        </div>
        <div class="mt-6 grid grid-cols-2 gap-3 auto-rows-fr">
          <div class="rounded-xl border border-base-300 bg-base-200/40 p-4 flex items-center gap-3">
            <i class="fa-solid fa-dumbbell text-xl"></i>
            <div>
              <div class="font-semibold">Dumbbells</div>
              <div class="text-xs opacity-70">Strength</div>
            </div>
          </div>
          <div class="rounded-xl border border-base-300 bg-base-200/40 p-4 flex items-center gap-3">
            <i class="fa-solid fa-shoe-prints text-xl"></i>
            <div>
              <div class="font-semibold">Running shoes</div>
              <div class="text-xs opacity-70">Cardio</div>
            </div>
          </div>
          <div class="rounded-xl border border-base-300 bg-base-200/40 p-4 flex items-center gap-3">
            <i class="fa-solid fa-dumbbell text-xl"></i>
            <div>
              <div class="font-semibold">Gym access</div>
              <div class="text-xs opacity-70">Machines</div>
            </div>
          </div>
          <div class="rounded-xl border border-base-300 bg-base-200/40 p-4 flex items-center gap-3">
            <i class="fa-solid fa-person-running text-xl"></i>
            <div>
              <div class="font-semibold">Treadmill</div>
              <div class="text-xs opacity-70">Endurance</div>
            </div>
          </div>
        </div>
        <div class="card-actions mt-auto justify-end pt-6">
          <button class="btn btn-outline btn-sm">Edit tools</button>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- Programs grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% @programs.each do |program| %>
    <%= link_to(program) do %>
      <div class="card bg-base-100 image-full w-96 shadow-sm group overflow-hidden">
        <figure class="overflow-hidden">
          <img
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        src="https://img.daisyui.com/images/stock/photo-1606107557195-0e29a4b5b4aa.webp"
        alt="Program">
        </figure>
        <div class="card-body relative flex flex-col">
          <!-- Level badge -->
          <div class="absolute top-4 left-4">
            <span class="badge badge-neutral font-semibold">Level • Intermediate</span>
          </div>
          <!-- Difficulty score -->
          <div class="absolute top-4 right-4 scale-75">
            <div
              class="radial-progress"
              style="--value:70;"
              aria-valuenow="70"
              role="progressbar"
              title="Difficulty">
              7/10
            </div>
          </div>
          <div class="mt-10">
            <div class="flex items-start gap-3">
              <i class="fa-solid fa-person-swimming text-4xl"></i>
              <div class="min-w-0">
                <h2 class="card-title leading-tight">
                  <%= program.title %>
                </h2>
                <p class="opacity-80">resume goal</p>
              </div>
            </div>
            <div class="mt-3 flex flex-wrap gap-2 items-center">
              <span class="badge badge-outline">8 weeks</span>
              <span class="badge badge-outline">goal</span>
              <span class="badge badge-outline flex items-center gap-2">
                <span>tools</span>
                <i class="fa-solid fa-shoe-prints"></i>
                <i class="fa-solid fa-person-running"></i>
              </span>
            </div>
          </div>
          <div class="card-actions mt-auto flex items-center justify-between pt-4">
            <progress class="progress progress-error w-40" value="70" max="100"></progress>
            <span class="btn btn-primary">Details</span>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
