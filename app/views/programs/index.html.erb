<%# app/views/programs/index.html.erb %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <!-- Hero motivation -->
  <div class="mt-6 mb-12 text-center">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight italic">
      Progress isn’t given.
      <span class="text-primary">It’s earned.</span>
    </h2>

    <p class="mt-4 text-sm opacity-70 max-w-xl mx-auto">
      Show up. Push harder. Build the version of yourself you’re capable of becoming.
    </p>
  </div>

  <!-- Dashboard -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">

    <!-- Performance overview (wider) -->
    <div class="lg:col-span-9">
      <div class="card bg-base-100 border border-base-300 shadow-sm h-full">
        <div class="card-body">

          <div class="flex items-start justify-between mb-6">
            <div>
              <h2 class="card-title flex items-center gap-2">
                <i class="fa-solid fa-chart-line"></i>
                Performance overview
              </h2>
              <p class="text-sm opacity-70">
                Readiness, consistency and weekly progression at a glance.
              </p>
            </div>

            <span class="badge badge-outline">
              Last 4 weeks
            </span>
          </div>

          <!-- KPI row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-8">

            <div class="rounded-2xl border border-base-300 bg-base-200/40 p-4">
              <div class="flex items-center justify-between">
                <div class="text-sm opacity-70">Readiness</div>
                <i class="fa-solid fa-heart-pulse opacity-70"></i>
              </div>

              <div class="mt-3 flex items-center justify-between">
                <div>
                  <div class="text-2xl font-semibold">76%</div>
                  <div class="text-xs opacity-70 mt-1">Good recovery</div>
                </div>

                <div class="radial-progress text-success scale-75" style="--value:76;" aria-valuenow="76" role="progressbar">
                  76
                </div>
              </div>
            </div>

            <div class="rounded-2xl border border-base-300 bg-base-200/40 p-4">
              <div class="flex items-center justify-between">
                <div class="text-sm opacity-70">Streak</div>
                <i class="fa-solid fa-fire-flame-curved opacity-70"></i>
              </div>

              <div class="text-2xl font-semibold mt-3">7 days</div>
              <div class="text-xs opacity-70 mt-1">
                Consistency beats motivation
              </div>
            </div>

            <div class="rounded-2xl border border-base-300 bg-base-200/40 p-4">
              <div class="flex items-center justify-between">
                <div class="text-sm opacity-70">Consistency</div>
                <i class="fa-solid fa-check opacity-70"></i>
              </div>

              <div class="text-2xl font-semibold mt-3">78%</div>
              <div class="text-xs opacity-70 mt-1">
                Sessions completed / planned
              </div>
            </div>

            <div class="rounded-2xl border border-base-300 bg-base-200/40 p-4">
              <div class="flex items-center justify-between">
                <div class="text-sm opacity-70">Avg intensity</div>
                <i class="fa-solid fa-gauge-high opacity-70"></i>
              </div>

              <div class="text-2xl font-semibold mt-3">6.4 / 10</div>
              <div class="text-xs opacity-70 mt-1">
                Perceived exertion
              </div>
            </div>

          </div>

          <!-- Progression + Heatmap -->
          <div class="grid grid-cols-1 xl:grid-cols-12 gap-4">

            <!-- Progression line -->
            <div class="xl:col-span-7">
              <div class="rounded-2xl border border-base-300 bg-base-200/40 p-6 h-full">

                <div class="flex items-center justify-between mb-6">
                  <div class="font-semibold">Weekly progression</div>
                  <span class="badge badge-outline">Training load</span>
                </div>

                <svg viewBox="0 0 320 120" class="w-full h-32">
                  <line x1="0" y1="100" x2="320" y2="100" stroke="currentColor" opacity="0.1"/>

                  <polyline
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    points="10,90 100,70 200,55 300,35"
                    class="text-primary"/>

                  <circle cx="10" cy="90" r="4" fill="currentColor"/>
                  <circle cx="100" cy="70" r="4" fill="currentColor"/>
                  <circle cx="200" cy="55" r="4" fill="currentColor"/>
                  <circle cx="300" cy="35" r="4" fill="currentColor"/>
                </svg>

                <div class="flex justify-between text-xs opacity-70 mt-3">
                  <span>Week 1</span>
                  <span>Week 2</span>
                  <span>Week 3</span>
                  <span>Week 4</span>
                </div>

              </div>
            </div>

            <!-- Heatmap -->
            <div class="xl:col-span-5">
              <div class="rounded-2xl border border-base-300 bg-base-200/40 p-6 h-full">

                <div class="flex items-center justify-between mb-4">
                  <div class="font-semibold">Training consistency</div>
                  <span class="badge badge-outline">28 days</span>
                </div>

                <p class="text-sm opacity-70 mb-4">
                  More filled squares = more training days. Keep the rhythm.
                </p>

                <% heat = [
                  [0,1,1,2,0,1,2],
                  [1,2,2,3,1,0,1],
                  [0,1,2,3,2,1,0],
                  [1,0,1,2,2,3,1]
                ] %>

                <div class="grid grid-cols-7 gap-2">
                  <% heat.flatten.each do |v| %>
                    <% bg =
                      case v
                      when 0 then "bg-base-100/40"
                      when 1 then "bg-primary/15"
                      when 2 then "bg-primary/30"
                      else "bg-primary/50"
                      end
                    %>
                    <div class="h-8 rounded-xl border border-base-300 <%= bg %>"></div>
                  <% end %>
                </div>

                <div class="mt-4 flex items-center justify-between text-xs opacity-70">
                  <span>Less</span>
                  <div class="flex items-center gap-2">
                    <span class="inline-block w-4 h-4 rounded border border-base-300 bg-base-100/40"></span>
                    <span class="inline-block w-4 h-4 rounded border border-base-300 bg-primary/15"></span>
                    <span class="inline-block w-4 h-4 rounded border border-base-300 bg-primary/30"></span>
                    <span class="inline-block w-4 h-4 rounded border border-base-300 bg-primary/50"></span>
                  </div>
                  <span>More</span>
                </div>

              </div>
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- Tools -->
    <div class="lg:col-span-3">
      <div class="card bg-base-100 border border-base-300 shadow-sm h-full">
        <div class="card-body flex flex-col p-5">

          <div class="flex items-start justify-between">
            <div>
              <h2 class="card-title flex items-center gap-2">
                <i class="fa-solid fa-toolbox"></i>
                Your tools
              </h2>
              <p class="text-sm opacity-70">
                Available equipment for your sessions
              </p>
            </div>

            <span class="badge badge-outline">
              Equipment
            </span>
          </div>

          <div class="mt-5 grid grid-cols-1 gap-3">

            <div class="rounded-2xl border border-base-300 bg-base-200/40 p-4 flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-2xl bg-base-100 border border-base-300">
                <i class="fa-solid fa-dumbbell text-sm opacity-80"></i>
              </span>
              <div class="min-w-0">
                <div class="font-semibold leading-tight">Dumbbells</div>
                <div class="text-xs opacity-70">Strength</div>
              </div>
            </div>

            <div class="rounded-2xl border border-base-300 bg-base-200/40 p-4 flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-2xl bg-base-100 border border-base-300">
                <i class="fa-solid fa-shoe-prints text-sm opacity-80"></i>
              </span>
              <div class="min-w-0">
                <div class="font-semibold leading-tight">Running shoes</div>
                <div class="text-xs opacity-70">Cardio</div>
              </div>
            </div>

            <div class="rounded-2xl border border-base-300 bg-base-200/40 p-4 flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-2xl bg-base-100 border border-base-300">
                <i class="fa-solid fa-kettlebell text-sm opacity-80"></i>
              </span>
              <div class="min-w-0">
                <div class="font-semibold leading-tight">Kettlebell</div>
                <div class="text-xs opacity-70">Conditioning</div>
              </div>
            </div>

            <div class="rounded-2xl border border-base-300 bg-base-200/40 p-4 flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-2xl bg-base-100 border border-base-300">
                <i class="fa-solid fa-person-running text-sm opacity-80"></i>
              </span>
              <div class="min-w-0">
                <div class="font-semibold leading-tight">Treadmill</div>
                <div class="text-xs opacity-70">Endurance</div>
              </div>
            </div>

          </div>

          <div class="card-actions mt-auto justify-end pt-5">
            <button class="btn btn-outline btn-sm gap-2">
              <i class="fa-solid fa-pen"></i>
              Edit tools
            </button>
          </div>

        </div>
      </div>
    </div>

  </div>

  <!-- Programs wrapper (full-width aligned, same borders as top cards) -->
  <div class="mt-10 card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body">

      <div class="flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight">
            Programs
          </h2>
          <p class="opacity-70 mt-1">
            Choose a program and keep progressing.
          </p>
        </div>

        <span class="badge badge-outline">
          Total: <%= @programs.count %>
        </span>
      </div>

      <div class="divider my-6"></div>

      <!-- Grid inside the wrapper (keeps same outer borders) -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @programs.each do |program| %>
          <%= render "shared/card", program: program %>
        <% end %>
      </div>

    </div>
  </div>
</div>
