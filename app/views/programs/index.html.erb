<h1 class="text-2xl font-bold mb-6">Mes programmes</h1>
<%= link_to "Créer un programme",
    new_program_path,
    class:"bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition" %>
<ul class="mt-6 space-y-2">
  <% @programs.each do |program| %>
    <li class="p-4 bg-white rounded shadow">
      <%= program.title.presence || "Programme ##{program.id}" %>
    </li>
  <% end %>
</ul>
<input type="checkbox" value="synthwave" class="toggle theme-controller">
<%= Kramdown::Document.new("### Friday: Performance Test + Stretching\n\nFinal evaluation and recovery session.\n\n**Performance Test:**\n- Time to complete 2 km run\n- Maximum push-ups in 1 minute\n- Maximum plank hold time\n\n**Recovery:**\n- 15–20 minutes full body stretching\n- Deep breathing exercises\n\n**Goal:** Evaluate progress, reinforce mobility, and properly conclude the program.").to_html.html_safe
%>
